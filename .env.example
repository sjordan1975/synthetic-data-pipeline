# OpenAI API Configuration Template
# Copy this file to .env.local and fill in your actual API credentials
# NEVER commit .env.local to version control

# OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
# Or use ChatAnywhere: https://api.chatanywhere.tech
OPENAI_API_KEY=your_api_key_here

# OpenAI Base URL (optional)
# Leave blank for official OpenAI API
# For ChatAnywhere, use: https://api.chatanywhere.tech/v1
OPENAI_BASE_URL=https://api.chatanywhere.tech/v1

# Tuning parameters for LLM judge
LLM_RETRY_MAX_ATTEMPTS=5
LLM_RETRY_BASE_DELAY_SECONDS=0.5
LLM_RETRY_MAX_DELAY_SECONDS=8.0
LLM_RETRY_JITTER_RATIO=0.2
LLM_BATCH_DELAY_SECONDS=0.0